<%- layout('layouts/boilerplate') -%>

<form method="GET" action="/listings/filter">
<div id="filters">

<input type="radio" class="btn-check" name="selected" id="trending" autocomplete="off">
<label class="btn" for="trending">
    <div class="filter">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="rooms" autocomplete="off" value="Rooms">
<label class="btn" for="rooms">
    <div class="filter">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="cities" autocomplete="off" value="Iconic Cities">
<label class="btn" for="cities">
    <div class="filter">
    <div><i class="fa-solid fa-city"></i>
    </div>
    <p>Iconic Cities</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="mountains" autocomplete="off" value="Mountains">
<label class="btn" for="mountains">
    <div class="filter">
    <div><i class="fa-solid fa-mountain"></i></div>
    <p>Mountains</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="castles" autocomplete="off" value="Castles">
<label class="btn" for="castles">
    <div class="filter">
    <div><i class="fa-brands fa-fort-awesome"></i></div>
    <p>Castles</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="pools" autocomplete="off" value="Amazing Pools">
<label class="btn" for="pools">
    <div class="filter">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>Amazing Pools</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="camping" autocomplete="off" value="Camping">
<label class="btn" for="camping">
    <div class="filter">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="farms" autocomplete="off" value="Farms">
<label class="btn" for="farms">
    <div class="filter">
    <div><i class="fa-solid fa-tractor"></i></div>
    <p>Farms</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="arctic" autocomplete="off" value="Arctic">
<label class="btn" for="arctic">
    <div class="filter">
    <div><i class="fa-solid fa-snowflake"></i></div>
    <p>Arctic</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="domes" autocomplete="off" value="Domes" >
<label class="btn" for="domes">
    <div class="filter">
    <div><i class="fa-solid fa-igloo"></i></div>
    <p>Domes</p>
    </div>
</label>

<input type="radio" class="btn-check" name="selected" id="boats" autocomplete="off" value="Boats">
<label class="btn" for="boats">
    <div class="filter">
    <div><i class="fa-solid fa-sailboat"></i></div>
    <p>Boats</p>
    </div>
</label>

 </form>

<div class="tax-toggle">
    <div class="form-check-reverse form-switch">
    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
</div>
</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
<% for( let listing of allListings ) { %>
    <a href="/listings/<%= listing._id %>" class="listing-links">
    <div class="card listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
        <div class="card-body">
            <h5 class="card-title"><%= listing.title %></h5>
            &#8377; <%= listing.price.toLocaleString("en-IN") %>/night
            <i id="tax-info" class="tax-info">&nbsp;&nbsp;(+18% GST)</i>
        </div>
    </div>       
    </a>
<% } %>    
</div>
